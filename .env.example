# Hermes Railway Template — Multi-Provider Setup
#mount volume: /data/hermes
#configure via: https://<host>/setup

# ─────────────────────────────────────────────
# LLM PROVIDER KEYS — isi SALAH SATU saja
# Hermes auto-detect dari key yang tersedia (prioritas atas → bawah)
# ─────────────────────────────────────────────

# 🔹 NVIDIA NIM (prioritas tertinggi)
# https://build.nvidia.com/explore/discover
NVIDIA_NIM_API_KEY=

# 🔹 Mistral AI
# https://console.mistral.ai/
MISTRAL_API_KEY=

# 🔹 GitHub Models
# https://github.com/marketplace/models
GITHUB_TOKEN=

# 🔹 Groq (super fast inference)
# https://console.groq.com/keys
GROQ_API_KEY=

# 🔹 OpenRouter (akses 100+ model)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 🔹 Cohere
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# 🔹 Cerebras
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# 🔹 HuggingFace Inference
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ─────────────────────────────────────────────
# OPTIONAL: Override base URL per provider
# ─────────────────────────────────────────────
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# GITHUB_BASE_URL=https://models.inference.ai.azure.com
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# COHERE_BASE_URL=https://api.cohere.ai/v2
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# HF_BASE_URL=https://api-inference.huggingface.co/v1

# ─────────────────────────────────────────────
# MODEL (opsional — default: auto)
# ─────────────────────────────────────────────
# Contoh:
# HERMES_MODEL=meta-llama/llama-3.1-70b-instruct
# HERMES_MODEL=mistral-large-latest
# HERMES_MODEL=llama-3.3-70b-versatile
HERMES_MODEL=auto

# ─────────────────────────────────────────────
# TELEGRAM (WAJIB untuk chat via Telegram)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# ─────────────────────────────────────────────
# SECURITY & API (opsional)
# ─────────────────────────────────────────────
API_SERVER_KEY=
GATEWAY_ALLOW_ALL_USERS=false

# ─────────────────────────────────────────────
# HERMES INTERNAL
# ─────────────────────────────────────────────
HERMES_HOME=/data/hermes