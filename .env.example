# Hermes Railway Template v2 — reference for Railway Variables and /setup
# Fresh deploy: mount volume at /data/hermes, configure via https://<host>/setup

# --- LLM (secrets → .env; model → config.yaml via /setup) ---
OPENROUTER_API_KEY=
# MODEL_DEFAULT is written to config.yaml as model.default (not .env)

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NOVITA_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=
OLLAMA_API_KEY=

# --- Recommended on public Railway URLs ---
API_SERVER_KEY=
GATEWAY_ALLOW_ALL_USERS=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_NAME=
# TELEGRAM_HOME_CHANNEL_THREAD_ID=
# Webhook mode (optional; path proxied on public URL):
# TELEGRAM_WEBHOOK_URL=https://your-service.up.railway.app/telegram
# TELEGRAM_WEBHOOK_SECRET=

# --- Discord ---
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# --- Slack ---
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=

# --- Microsoft Teams (webhook URL: https://<host>/api/messages) ---
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=
# TEAMS_TENANT_ID=
# TEAMS_ALLOWED_USERS=
# TEAMS_ALLOW_ALL_USERS=false

# --- Advanced API ---
# API_SERVER_CORS_ORIGINS=
# API_SERVER_MODEL_NAME=
# WEBHOOK_ENABLED=true
# WEBHOOK_SECRET=

HERMES_HOME=/data/hermes

# --- Optional: connect Railway container to your Tailscale tailnet ---
# TAILSCALE_AUTHKEY=tskey-auth-...
# TAILSCALE_HOSTNAME=hermes-railway
# TAILSCALE_EXTRA_ARGS=--accept-routes

# --- Optional: local OpenAI-compatible endpoint via Tailscale ---
# Use your PC's Tailscale IP, not localhost.
# Example for Zed's PC:
# HERMES_PROVIDER=custom
# HERMES_MODEL=local-model-name
# HERMES_BASE_URL=http://100.64.73.96:20128/v1
# HERMES_API_KEY=local-not-needed
